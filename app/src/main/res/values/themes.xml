<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fullscreen, no action bar. Platform Material theme (minSdk 29). -->
    <style name="Theme.Weldrite" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/brand_blue_dark</item>
        <item name="android:statusBarColor">@color/brand_blue_dark</item>
        <item name="android:navigationBarColor">@color/brand_blue_dark</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
